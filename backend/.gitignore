# === AgroMind Backend — Python/FastAPI/GCP .gitignore ===

# ──────────────────────────────────────────────────────────
# 🔴 SECRETS & CREDENTIALS (highest priority)
# ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example
gee-key.json
*-key.json
*-credentials.json
service-account*.json
credentials.json

# ──────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.Python

# ──────────────────────────────────────────────────────────
# Virtual Environment
# ──────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ──────────────────────────────────────────────────────────
# Testing & Coverage
# ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ──────────────────────────────────────────────────────────
# IDE
# ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ──────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────
# Docker (local overrides only)
# ──────────────────────────────────────────────────────────
docker-compose.override.yml